# NextAuth Configuration
# Run `openssl rand -base64 32` to generate a secure secret
NEXTAUTH_SECRET=your_generated_secret_here
# URL of your application (must match exactly)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Credentials
# 1. Go to https://console.cloud.google.com/
# 2. Create a project > APIs & Services > Credentials
# 3. Create OAuth client ID (Web application)
# 4. Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_ID=your_google_client_id_here
GOOGLE_SECRET=your_google_client_secret_here

# Apple OAuth Credentials
# 1. Sign in to Apple Developer Account
# 2. Register an App ID and a Services ID
# 3. Configure the Return URL for your Services ID: http://localhost:3000/api/auth/callback/apple
# 4. Generate a private key
APPLE_ID=your_apple_client_id_here
APPLE_SECRET=your_generated_apple_client_secret_here

# Microsoft (Azure AD) OAuth Credentials
# 1. Go to Azure Portal > Microsoft Entra ID (Azure AD)
# 2. App registrations > New registration
# 3. Add Reply URL: http://localhost:3000/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=your_microsoft_client_id_here
AZURE_AD_CLIENT_SECRET=your_microsoft_client_secret_here
AZURE_AD_TENANT_ID=your_microsoft_tenant_id_here
